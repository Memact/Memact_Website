{
  "manifest_version": 3,
  "name": "Memact",
  "version": "0.2.0",
  "description": "Capture browser tab context for Memact.",
  "permissions": ["tabs", "windows", "scripting"],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:38453/*",
    "http://localhost:38453/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Memact"
  }
}
